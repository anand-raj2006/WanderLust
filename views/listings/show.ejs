<% layout('layouts/boilerplate') %>

    <div class="row justify-content-center align-items-center"
        style="min-height: calc(100vh - 11rem); padding: 0.75rem 0;">
        <div class="col-12 col-lg-11">
            <div class="card shadow-sm overflow-hidden">
                <div class="row g-0" style="min-height: 70vh;">
                    <% const rawImageUrl=(listing.image && listing.image.url) ? listing.image.url : (typeof
                        listing.image==='string' ? listing.image : '' ); %>
                        <% const imageUrl=(rawImageUrl && !rawImageUrl.includes('unsplash.com/photos/')) ? rawImageUrl
                            : 'https://images.unsplash.com/photo-1464983953574-0892a716854b?auto=format&fit=crop&w=1200&q=80'
                            ; %>
                            <div class="col-lg-8">
                                <img src="<%= imageUrl %>" alt="<%= listing.title %>" class="show-listing-image"
                                    style="width: 100%; height: 70vh; object-fit: cover;">
                            </div>
                            <div class="col-lg-4 d-flex">
                                <div class="card-body p-3 d-flex flex-column w-100">
                                    <h2 class="card-title fw-bold mb-2">
                                        <%= listing.title %>
                                    </h2>

                                    <p class="mb-2" style="font-size: 0.95rem;">
                                        <%= listing.description %>
                                    </p>

                                    <p class="mb-1"><strong>Location:</strong>
                                        <%= listing.location %>
                                    </p>
                                    <p class="mb-1"><strong>Country:</strong>
                                        <%= listing.country %>
                                    </p>
                                    <p class="mb-1"><strong>Owned by:</strong>
                                        <%= listing.owner && listing.owner.username ? listing.owner.username : 'Unknown'
                                            %>
                                    </p>
                                    <p class="mb-3"><strong>Price:</strong> Ruppe <%= listing.price %>/night</p>

                                    <% const isListingOwner=currentUser && listing.owner &&
                                        String(currentUser._id)===String(listing.owner._id || listing.owner); %>
                                        <% if (isListingOwner) { %>
                                            <div class="mt-auto d-flex gap-2">
                                                <a href="/listings/<%= listing._id %>/edit"
                                                    class="btn btn-dark btn-sm">Edit</a>
                                                <form action="/listings/<%= listing._id %>?_method=DELETE" method="POST"
                                                    class="m-0">
                                                    <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                                </form>
                                            </div>
                                            <% } %>
                                </div>
                            </div>
                </div>
            </div>
            <div class="card shadow-sm mt-3">
                <div class="card-body p-3">
                    <h4 class="mb-3">Leave a Review</h4>
                    <form action="/listings/<%= listing._id %>/reviews" method="POST" novalidate
                        class="needs-validation">
                        <fieldset class="starability-slot">
                            <input type="radio" id="no-rate" class="input-no-rate" name="review[rating]" value="0"
                                aria-label="No rating." />
                            <input type="radio" id="first-rate1" name="review[rating]" value="1" />
                            <label for="first-rate1" title="Terrible">1 star</label>
                            <input type="radio" id="first-rate2" name="review[rating]" value="2" />
                            <label for="first-rate2" title="Not good">2 stars</label>
                            <input type="radio" id="first-rate3" name="review[rating]" value="3" checked />
                            <label for="first-rate3" title="Average">3 stars</label>
                            <input type="radio" id="first-rate4" name="review[rating]" value="4" />
                            <label for="first-rate4" title="Very good">4 stars</label>
                            <input type="radio" id="first-rate5" name="review[rating]" value="5" />
                            <label for="first-rate5" title="Amazing">5 stars</label>
                        </fieldset>
                        <div class="mb-3">
                            <label for="comment" class="form-label">Comment</label>
                            <textarea class="form-control" id="comment" name="review[comment]" rows="4"
                                placeholder="Share your experience" required></textarea>
                            <div class="invalid-feedback">Please provide a comment.</div>
                        </div>
                        <button type="submit" class="btn btn-dark">Submit Review</button>
                    </form><br>
                    <h4 class="mb-3">All Reviews</h4>
                    <% if (listing.reviews.length) { %>
                        <div class="row row-cols-1 row-cols-md-2 g-3">
                            <% listing.reviews.forEach(review=> { %>
                                <div class="col">
                                    <div class="card h-100 review-card">
                                        <div class="card-body p-3">
                                            <div class="d-flex justify-content-between align-items-start mb-3">
                                                <div>
                                                    <p class="mb-0 fw-semibold review-author">
                                                        <%= review.author.username %>
                                                    </p>
                                                    <p class="starability-result" data-rating="<%= review.rating %>">
                                                    </p>
                                                    <small class="review-meta">Posted a review</small>
                                                </div>
                                                <span class="badge text-bg-dark px-3 py-2 rounded-pill">
                                                    <%= review.rating %>/5
                                                </span>
                                            </div>
                                            <h6 class="review-comment">
                                                <%= review.comment %>
                                            </h6>
                                            <% const canDeleteReview=currentUser && review.author &&
                                                String(currentUser._id)===String(review.author._id || review.author); %>
                                                <% if (canDeleteReview) { %>
                                                    <form
                                                        action="/listings/<%= listing._id %>/reviews/<%= review._id %>?_method=DELETE"
                                                        method="POST">
                                                        <button type="submit" class="btn-sm">Delete Review</button>
                                                    </form>
                                                    <% } %>
                                        </div>
                                    </div>
                                </div>
                                <% }); %>
                        </div>
                        <% } else { %>
                            <p class="text-muted mb-0">No reviews yet. Be the first to review this listing.</p>
                            <% } %>

                </div>
            </div>
            <div class="card shadow-sm mt-3">
                <div class="card-body p-3">
                    <h4 class="mb-3">Where you'll be</h4>
                    <div id="map" data-lat="<%= listing.geometry && listing.geometry.lat ? listing.geometry.lat : '' %>"
                        data-lng="<%= listing.geometry && listing.geometry.lng ? listing.geometry.lng : '' %>"
                        data-title="<%= listing.title %>"
                        data-location="<%= listing.location %>, <%= listing.country %>"
                        style="height: 400px; width: 100%; border-radius: 10px; overflow: hidden; box-shadow: 0 4px 14px rgba(0,0,0,0.12);">
                    </div>
                </div>
            </div>

            <link rel="stylesheet" href="https://unpkg.com/leaflet/dist/leaflet.css" />
            <script src="https://unpkg.com/leaflet/dist/leaflet.js"></script>

            <script>
                const mapEl = document.getElementById('map');
                const storedLat = mapEl.dataset.lat ? parseFloat(mapEl.dataset.lat) : null;
                const storedLng = mapEl.dataset.lng ? parseFloat(mapEl.dataset.lng) : null;
                const listingLocation = mapEl.dataset.location;
                const listingTitle = mapEl.dataset.title;
                const popupText = mapEl.dataset.location;

                function initMap(lat, lng) {
                    const map = L.map('map').setView([lat, lng], 12);
                    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
                        attribution: '&copy; <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a> contributors'
                    }).addTo(map);
                    L.marker([lat, lng]).addTo(map)
                        .bindPopup(`<strong>${listingTitle}</strong><br>${popupText}`)
                        .openPopup();
                }

                if (storedLat !== null && storedLng !== null) {
                    initMap(storedLat, storedLng);
                } else {
                    // Fallback: geocode on the client for listings created before geocoding was added
                    fetch(`https://nominatim.openstreetmap.org/search?q=${encodeURIComponent(listingLocation)}&format=json&limit=1`)
                        .then(r => r.json())
                        .then(data => {
                            if (data && data.length > 0) {
                                initMap(parseFloat(data[0].lat), parseFloat(data[0].lon));
                            } else {
                                initMap(20, 0);
                            }
                        })
                        .catch(() => initMap(20, 0));
                }
            </script>
        </div>
    </div>